# Tells GitHub what to exclude in the repo (API keys, temporary files)

# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
myenv/
.venv/
venv/
ENV/
env/

# Local env vars (keep .env.example committed)
.env
.env.*
!.env.example

# Flask sessions / caches
flask_session/

# OS / editor junk
.DS_Store
.vscode/

# Outputs generated by this project
playlist
playlist.csv
output/
/*.csv
